# Data: keep the folder via .gitkeep, ignore everything else
/data/**
!/data/.gitkeep

# Logs: keep the folder structure (.gitkeep files), ignore all log content
/logs/**
!/logs/**/
!/logs/**/.gitkeep

# Frontend root in /www stays tracked, but nested project folders do not
/www/*/

# SSL certs/keys must never be committed
/config/ssl/**
!/config/ssl/.gitkeep
